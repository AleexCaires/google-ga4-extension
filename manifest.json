{
  "manifest_version": 3,
  "name": "GA4 Event Spy",
  "version": "1.4.0",
  "description": "Watches outgoing GA4 hits and shows every event as it fires, with parameters.",
  "permissions": ["webRequest", "storage", "sidePanel"],
  "host_permissions": [
    "*://*/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "side_panel": {
    "default_path": "panel.html"
  },
  "action": {
    "default_title": "GA4 Event Spy"
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
